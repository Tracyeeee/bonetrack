/* 全局样式 - Bonetrack 骨迹康复管理小程序 */

page {
  --bg-color: #0A0A0A;
  --primary-color: #FF4D00;
  --secondary-color: #007AFF;
  --text-primary: #FFFFFF;
  --text-secondary: #888888;
  --text-muted: #555555;
  --card-bg: #1A1A1A;
  --nav-bar-bottom-gap: 36rpx;

  background-color: var(--bg-color);
  color: var(--text-primary);
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 顶部导航栏样式 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  padding-top: 44rpx;
  background-color: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 1000;
  padding-left: 30rpx;
  padding-right: 30rpx;
}

.nav-bar-title {
  font-size: 36rpx;
  font-weight: 600;
}

.nav-bar-user {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid var(--primary-color);
}

.nav-bar-user image {
  width: 100%;
  height: 100%;
}

/* 底部导航栏样式（由 tabBar 自动处理） */

/* 通用卡片样式 */
.card {
  background-color: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.card-content {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 数字强调样式 */
.big-number {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.medium-number {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--primary-color);
  color: var(--text-primary);
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background-color: var(--secondary-color);
  color: var(--text-primary);
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-outline {
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
}

/* 输入框样式 */
.input-field {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  background-color: rgba(255, 77, 0, 0.15);
  color: var(--primary-color);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: rgba(255, 255, 255, 0.1);
  margin: 30rpx 0;
}

/* Flex 布局工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-align-center {
  display: flex;
  align-items: center;
}

/* 文本样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-orange {
  color: var(--primary-color);
}

.text-blue {
  color: var(--secondary-color);
}

/* 字号 */
.text-h1 {
  font-size: 40rpx;
  font-weight: 700;
}

.text-h2 {
  font-size: 36rpx;
  font-weight: 600;
}

.text-h3 {
  font-size: 32rpx;
  font-weight: 600;
}

.text-body {
  font-size: 28rpx;
  font-weight: 400;
}

.text-caption {
  font-size: 24rpx;
  font-weight: 400;
}

/* 间距工具类 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }

.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.mb-40 { margin-bottom: 40rpx; }

.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }

.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }

.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 圆形头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
}

.avatar-large {
  width: 120rpx;
  height: 120rpx;
}

/* 橙色光晕效果 */
.avatar-glow {
  border: 3rpx solid var(--primary-color);
  box-shadow: 0 0 20rpx rgba(255, 77, 0, 0.4);
}

/* 时间轴胶卷样式 */
.timeline-strip {
  display: flex;
  overflow-x: auto;
  padding: 30rpx;
  gap: 20rpx;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}

.timeline-day {
  flex-shrink: 0;
  width: 120rpx;
  height: 140rpx;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.timeline-day-today {
  border: 3rpx solid var(--primary-color);
  box-shadow: 0 0 30rpx rgba(255, 77, 0, 0.3);
}

.timeline-day-completed {
  background-color: rgba(255, 77, 0, 0.2);
}

.timeline-day-thumbnail {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  object-fit: cover;
}

.timeline-day-value {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* 悬浮打卡按钮 */
.fab-checkin {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(255, 77, 0, 0.5);
  z-index: 999;
}

.fab-checkin:active {
  transform: translateX(-50%) scale(0.95);
}

.fab-checkin-icon {
  font-size: 60rpx;
  color: var(--text-primary);
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(180deg, var(--bg-color) 0%, #1A1A1A 100%);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-muted);
}

.empty-state-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state-text {
  font-size: 28rpx;
}
