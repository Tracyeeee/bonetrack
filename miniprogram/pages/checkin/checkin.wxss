/* pages/checkin/checkin.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 200rpx;
}

/* 导航栏 - 沉浸式覆盖 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #1A1A1A;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  height: 88rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
}

/* 内容区域 */
.content {
  padding: 35rpx 0;
}

/* 模块卡片 */
.module-card {
  margin: 20rpx 30rpx;
  padding: 0;
  overflow: hidden;
}

.module-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
}

.module-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.module-info {
  display: flex;
  flex-direction: column;
}

.module-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.module-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.module-toggle {
  color: var(--text-muted);
  font-size: 24rpx;
  transition: transform 0.3s ease;
}

.module-toggle.expanded {
  color: var(--primary-color);
}

/* 模块内容 */
.module-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  padding: 0 30rpx;
}

.module-content.show {
  max-height: 800rpx;
  padding: 0 30rpx 30rpx;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.6);
  color: var(--text-primary);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add {
  aspect-ratio: 1;
  border: 2rpx dashed var(--text-muted);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-add-icon {
  font-size: 48rpx;
  color: var(--text-muted);
  line-height: 1;
}

.photo-add-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.module-hint {
  display: block;
  text-align: right;
  margin-top: 16rpx;
}

/* 角度显示 */
.current-angle-display {
  text-align: center;
  padding: 30rpx;
  background-color: rgba(255, 77, 0, 0.1);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.display-label {
  display: block;
  margin-bottom: 10rpx;
}

.display-value {
  font-size: 64rpx;
  font-weight: 700;
}

/* 快速选项 */
.quick-options,
.custom-input-section,
.direct-input-section,
.quick-weight-options,
.custom-weight-section {
  margin-top: 20rpx;
}

.option-label {
  display: block;
  margin-bottom: 16rpx;
}

.option-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-tag {
  padding: 16rpx 28rpx;
  background-color: var(--card-bg);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.option-tag.active {
  background-color: rgba(255, 77, 0, 0.2);
  color: var(--primary-color);
  border-color: var(--primary-color);
}

/* 输入组 */
.input-group {
  display: flex;
  gap: 20rpx;
}

.angle-input {
  flex: 1;
}

.btn-confirm-angle {
  width: 160rpx;
  height: 88rpx;
  line-height: 88rpx;
  background-color: var(--primary-color);
  color: var(--text-primary);
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 0;
}

.direct-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.direct-angle-input {
  flex: 1;
  padding-right: 60rpx;
}

.input-unit {
  position: absolute;
  right: 30rpx;
  color: var(--text-secondary);
}

/* 负重相关 */
.current-weight-display {
  text-align: center;
  padding: 30rpx;
  background-color: rgba(76, 217, 100, 0.1);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.unit-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background-color: var(--card-bg);
  border-radius: 12rpx;
}

.weight-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.weight-btn {
  padding: 16rpx 28rpx;
  background-color: var(--card-bg);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.weight-btn.active {
  background-color: rgba(76, 217, 100, 0.2);
  color: #4CD964;
  border-color: #4CD964;
}

.custom-weight-input {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.weight-input {
  flex: 1;
}

/* 摘要卡片 */
.summary-card {
  margin: 20rpx 30rpx;
  padding: 30rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.summary-items {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
}

.summary-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.summary-icon {
  font-size: 32rpx;
}

.summary-text {
  color: var(--text-secondary);
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background-color: var(--bg-color);
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.action-btn-large {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--text-primary);
}

.btn-secondary {
  background-color: var(--card-bg);
  color: var(--text-primary);
}
