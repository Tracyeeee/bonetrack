/* pages/profile/profile.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 200rpx;
}

/* 导航栏 */
.nav-bar {
  background-color: #1A1A1A;
  z-index: 100;
  width: 100%;
  box-sizing: border-box;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx 20rpx;
  box-sizing: border-box;
  min-height: 88rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  width: 120rpx;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-right {
  width: 120rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  color: #FFFFFF;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
}

/* 内容区域 */
.content {
  padding: 30rpx 0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  color: var(--text-primary);
}

/* 进度指示器 */
.progress-header {
  padding: 60rpx 60rpx 40rpx;
  text-align: center;
}

.step-indicators {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.step-dot {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: var(--card-bg);
  border: 3rpx solid var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transition: all 0.3s ease;
}

.step-dot.active {
  background-color: var(--primary-color);
  border-color: var(--primary-color);
}

.step-dot.completed {
  background-color: var(--primary-color);
  border-color: var(--primary-color);
}

.step-number {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-muted);
}

.step-dot.active .step-number,
.step-dot.completed .step-number {
  color: var(--text-primary);
}

.step-check {
  font-size: 24rpx;
  color: var(--text-primary);
}

.step-lines {
  position: absolute;
  display: flex;
  gap: 100rpx;
}

.step-line {
  width: 100rpx;
  height: 3rpx;
  background-color: var(--text-muted);
  transition: background-color 0.3s ease;
}

.step-line.active {
  background-color: var(--primary-color);
}

.step-label {
  margin-top: 20rpx;
}

/* 步骤内容 */
.step-content {
  padding: 0 40rpx;
}

.step-title {
  margin-bottom: 50rpx;
}

.step-title .text-h2 {
  display: block;
}

/* 选择区块 */
.selection-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
}

/* 选择网格 */
.selection-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.selection-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: var(--card-bg);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.selection-item.selected {
  border-color: var(--primary-color);
  background-color: rgba(255, 77, 0, 0.1);
}

.item-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 选择标签 */
.selection-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.selection-tag {
  padding: 16rpx 32rpx;
  background-color: var(--card-bg);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.selection-tag.selected {
  background-color: rgba(255, 77, 0, 0.15);
  color: var(--primary-color);
  border-color: var(--primary-color);
}

/* 日期选择 */
.date-picker-section {
  margin-top: 30rpx;
}

.date-display {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
}

.date-label {
  display: block;
  margin-bottom: 16rpx;
}

.date-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
  min-height: 48rpx;
}

.date-value.placeholder {
  color: var(--text-muted);
}

.picker-arrow {
  font-size: 40rpx;
  color: var(--text-muted);
}

/* 确保picker可点击 */
.date-display picker {
  width: 100%;
}

.days-info {
  text-align: center;
  padding: 40rpx;
}

.days-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-top: 16rpx;
}

/* 快捷日期 */
.quick-dates {
  padding: 0 10rpx;
}

.quick-date-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-date-tag {
  padding: 14rpx 28rpx;
  background-color: var(--card-bg);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 输入区块 */
.input-section {
  margin-bottom: 30rpx;
}

/* 原因网格 */
.cause-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.cause-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.cause-item.selected {
  border-color: var(--primary-color);
  background-color: rgba(255, 77, 0, 0.1);
}

.cause-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.cause-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.cause-item.selected .cause-name {
  color: var(--primary-color);
}

/* 运动背景网格 */
.background-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.background-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.background-item.selected {
  border-color: var(--primary-color);
  background-color: rgba(255, 77, 0, 0.1);
}

.background-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.background-item.selected .background-name {
  color: var(--primary-color);
}

/* 简历摘要 */
.profile-summary {
  padding: 30rpx;
}

.summary-header {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.summary-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-label {
  flex-shrink: 0;
}

.summary-value {
  text-align: right;
  font-weight: 500;
}

/* 授权说明 */
.auth-notice {
  padding: 0 10rpx;
}

.notice-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.notice-icon {
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(76, 217, 100, 0.2);
  color: #4CD964;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.notice-text {
  flex: 1;
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background-color: var(--bg-color);
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.action-back {
  padding: 20rpx 30rpx;
}

.action-next {
  flex: 1;
  margin-left: 20rpx;
}

.action-next.full-width {
  margin-left: 0;
}

.auth-buttons {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.auth-buttons button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background-color: var(--primary-color);
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 600;
}

.skip-btn {
  padding: 10rpx 20rpx;
}

/* 自定义输入相关样式 */
.custom-tag {
  border-style: dashed !important;
  color: var(--primary-color) !important;
  background-color: rgba(255, 77, 0, 0.08) !important;
}

.selection-tag.selected.custom-tag {
  border-style: solid !important;
}

.custom-input-wrapper {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  animation: fadeIn 0.2s ease;
}

.custom-input-wrapper.show {
  display: flex;
}

.custom-input {
  flex: 1;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

.custom-confirm-btn {
  padding: 24rpx 32rpx;
  background-color: var(--primary-color);
  color: var(--text-primary);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 治疗方式选择样式 */
.treatment-options {
  display: flex;
  gap: 20rpx;
}

.treatment-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background-color: var(--card-bg);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.treatment-item.selected {
  border-color: var(--primary-color);
  background-color: rgba(255, 77, 0, 0.1);
}

.treatment-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.treatment-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.treatment-item.selected .treatment-name {
  color: var(--primary-color);
}

.treatment-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 自定义损伤原因样式 */
.custom-cause {
  border-style: dashed !important;
  color: var(--primary-color) !important;
}

.custom-cause .cause-icon,
.custom-cause .cause-name {
  color: var(--primary-color) !important;
}

.cause-item.selected.custom-cause {
  border-style: solid !important;
}

/* 运动类型细分网格 */
.sports-sub-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

/* 运动多选网格 */
.sports-multi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.sports-multi-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background-color: var(--card-bg);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.sports-multi-item.selected {
  border-color: var(--primary-color);
  background-color: rgba(255, 77, 0, 0.1);
}

.sports-multi-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.sports-multi-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

.sports-multi-item.selected .sports-multi-name {
  color: var(--primary-color);
}

.custom-sports {
  border-style: dashed;
  border-color: var(--text-muted);
}

.custom-sports.selected {
  border-style: solid;
  border-color: var(--primary-color);
}

/* 已选运动标签 */
.selected-sports-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.selected-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(255, 77, 0, 0.1);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--primary-color);
}

.tag-close {
  font-size: 28rpx;
  color: var(--primary-color);
  margin-left: 4rpx;
}

/* 自定义导航栏 */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 160rpx 30rpx 40rpx;
  background-color: #0A0A0A;
  position: relative;
}

.nav-left, .nav-right {
  width: 150rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #FFFFFF;
}

.back-btn {
  font-size: 32rpx;
  color: #FFFFFF;
  padding: 10rpx 0;
  white-space: nowrap;
}

/* 确认弹窗 */
.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 560rpx;
  background-color: #1A1A1A;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.modal-title {
  text-align: center;
  color: #FFFFFF;
  margin-bottom: 40rpx;
  display: block;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background-color: rgba(255, 255, 255, 0.1);
  color: #999999;
}

.modal-btn.save {
  background-color: #FF4D00;
  color: #FFFFFF;
}
