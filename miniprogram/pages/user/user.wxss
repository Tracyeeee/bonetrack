/* pages/user/user.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

/* 导航栏 - 沉浸式覆盖 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #1A1A1A;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  height: 88rpx;
  box-sizing: border-box;
}

.nav-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  color: #FFFFFF;
  margin-right: 10rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
  white-space: nowrap;
}

.nav-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  min-width: 80rpx;
}

.edit-btn {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 内容区域 */
.content {
  padding: 35rpx 0;
}

/* 用户卡片 */
.user-card {
  margin: 20rpx 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, var(--card-bg) 0%, rgba(255, 77, 0, 0.08) 100%);
}

.user-header {
  display: flex;
  align-items: center;
}

.user-avatar-wrapper {
  margin-right: 24rpx;
}

.avatar-container {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--card-bg);
}

.avatar-container.glow {
  border: 3rpx solid var(--primary-color);
  box-shadow: 0 0 30rpx rgba(255, 77, 0, 0.4);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.user-tag {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 6rpx 14rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
}

.user-tag.text-orange {
  background-color: rgba(255, 77, 0, 0.15);
}

/* 统计区块 */
.stats-section {
  padding: 0 30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stat-card {
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.stat-label {
  font-size: 22rpx;
}

/* 康复进度区块 */
.progress-section {
  padding: 0 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 24rpx;
}

.progress-card {
  padding: 30rpx;
}

/* 角度进度 */
.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 进度条 */
.progress-bar-wrapper {
  width: 100%;
}

.progress-bar {
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: var(--primary-color);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

/* 成就徽章 */
.badges-section {
  padding: 0 30rpx;
}

.badges-scroll {
  margin-top: 10rpx;
  white-space: nowrap;
}

.badges-track {
  display: inline-flex;
  gap: 20rpx;
  padding: 10rpx 0;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  padding: 24rpx 16rpx;
  background-color: var(--card-bg);
  border-radius: 20rpx;
}

.badge-item.locked {
  opacity: 0.5;
}

.badge-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.badge-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* 训练进度 */
.task-progress {
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.task-progress-row {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
}

.task-progress-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.task-progress-circle {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.task-progress-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.task-progress-total {
  font-size: 28rpx;
  color: var(--text-muted);
}

.task-progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.task-progress-fill {
  height: 100%;
  background-color: var(--primary-color);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 菜单区块 */
.menu-section {
  padding: 0 30rpx;
}

.menu-list {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 40rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
}

/* ============ 编辑资料弹窗 ============ */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.edit-modal.show {
  opacity: 1;
  visibility: visible;
}

.edit-modal .modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.edit-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.edit-modal.show .edit-content {
  transform: translateY(0);
}

.edit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.edit-cancel {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 10rpx 20rpx;
}

.edit-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.edit-confirm {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
  padding: 10rpx 20rpx;
}

.edit-avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.edit-avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.edit-avatar-image,
.edit-avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-color);
  font-size: 72rpx;
}

.edit-avatar-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.edit-field {
  padding: 0 30rpx 40rpx;
}

.edit-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.edit-input {
  width: 100%;
  height: 96rpx;
  padding: 0 30rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.edit-input::placeholder {
  color: var(--text-muted);
}
