<!--pages/user/user.wxml-->
<wxs module="utils" src="../../utils.wxs"></wxs>
<view class="page-container">
  <!-- 顶部导航栏 - 动态高度 -->
  <view class="nav-bar" style="height: {{navBarHeight}};">
    <!-- 导航内容行 -->
    <view class="nav-content">
      <text class="page-title">个人中心</text>
    </view>
  </view>

  <scroll-view class="content" scroll-y="{{true}}" style="margin-top: {{navBarHeight}};">
    <!-- 用户信息卡片 -->
    <view class="user-card card gradient-bg" bindtap="onAvatarCardTap">
      <view class="user-header">
        <view class="user-avatar-wrapper">
          <view class="avatar-container {{userInfo.isAuthorized ? 'glow' : ''}}">
            <image wx:if="{{userInfo.avatar}}" class="avatar-image" src="{{userInfo.avatar}}" mode="aspectFill"></image>
            <text wx:else class="avatar-placeholder">👤</text>
          </view>
        </view>
        <view class="user-info">
          <text class="user-nickname text-h2">{{userInfo.nickname}}</text>
          <view class="user-tags mt-10">
            <text class="user-tag text-caption">{{userInfo.injuryPart}}</text>
            <text class="user-tag text-caption">{{userInfo.injuryType}}</text>
            <text class="user-tag text-caption text-orange">术后{{userInfo.daysSinceSurgery}}天</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 康复进度 -->
    <view class="progress-section mt-30">
      <view class="section-header flex-between">
        <text class="section-title text-h3">康复进度</text>
      </view>
      
      <view class="progress-card card">
        <!-- 角度进度 -->
        <view class="angle-progress">
          <view class="progress-header">
            <text class="text-caption text-secondary">当前弯腿角度</text>
            <text class="text-caption text-secondary">目标：{{progress.targetAngle}}°</text>
          </view>
          <view class="angle-display mt-20">
            <text class="angle-value big-number text-orange">{{progress.latestAngle}}</text>
            <text class="angle-unit text-h3 text-secondary">°</text>
          </view>
          <view class="progress-bar-wrapper mt-20">
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{progress.latestAngle / progress.targetAngle * 100}}%;"></view>
            </view>
            <view class="progress-labels flex-between mt-10">
              <text class="text-caption text-muted">0°</text>
              <text class="text-caption text-orange">{{utils.round(progress.latestAngle / progress.targetAngle * 100, 0)}}%</text>
              <text class="text-caption text-muted">{{progress.targetAngle}}°</text>
            </view>
          </view>
        </view>

        <!-- 训练进度 -->
        <view class="task-progress mt-30">
          <view class="progress-header">
            <text class="text-caption text-secondary">今日训练</text>
          </view>
          <view class="task-progress-row mt-20">
            <view class="task-progress-item">
              <view class="task-progress-circle">
                <text class="task-progress-value">{{progress.todayCompletion}}</text>
                <text class="task-progress-total">/{{progress.todayTotal}}</text>
              </view>
              <view class="task-progress-bar">
                <view class="task-progress-fill" style="width: {{progress.todayTotal > 0 ? progress.todayCompletion / progress.todayTotal * 100 : 0}}%;"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 菜单列表 -->
    <view class="menu-section mt-30">
      <view class="menu-list card">
        <view 
          class="menu-item"
          wx:for="{{menuItems}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onMenuTap"
        >
          <view class="menu-left">
            <text class="menu-icon">{{item.icon}}</text>
            <text class="menu-name text-body">{{item.name}}</text>
          </view>
          <view class="menu-right" wx:if="{{item.arrow}}">
            <text class="menu-arrow text-muted">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="version-info mt-40 mb-40">
      <text class="text-caption text-muted">Bonetrack 骨迹 v1.0.0</text>
    </view>
  </scroll-view>

  <!-- 编辑昵称/头像弹窗 -->
  <view class="edit-modal {{showEditModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <view class="modal-mask" bindtap="closeEditModal"></view>
    <view class="edit-content">
      <view class="edit-header">
        <text class="edit-cancel" bindtap="closeEditModal">取消</text>
        <text class="edit-title">编辑资料</text>
        <text class="edit-confirm" bindtap="confirmEdit">保存</text>
      </view>

      <!-- 头像编辑 -->
      <view class="edit-avatar-section">
        <view class="edit-avatar-wrapper" bindtap="chooseAvatar">
          <image wx:if="{{editForm.avatar}}" class="edit-avatar-image" src="{{editForm.avatar}}" mode="aspectFill"></image>
          <text wx:else class="edit-avatar-placeholder">👤</text>
          <view class="edit-avatar-tip">点击更换头像</view>
        </view>
      </view>

      <!-- 昵称编辑 -->
      <view class="edit-field">
        <text class="edit-label">昵称</text>
        <input
          class="edit-input"
          type="text"
          placeholder="请输入昵称"
          value="{{editForm.nickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
    </view>
  </view>
</view>
