/* pages/index/index.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--bg-color);
}

/* 导航栏 - 沉浸式覆盖 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #1A1A1A;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  height: 83rpx;
  box-sizing: border-box;
}

.nav-right {
  position: absolute;
  right: 30rpx;
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
}

.nav-user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-user-avatar image {
  width: 100%;
  height: 100%;
}

.nav-user-icon {
  font-size: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
}

.avatar-wrapper {
  position: relative;
  width: 60rpx;
  height: 60rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-ring {
  position: absolute;
  top: -3rpx;
  left: -3rpx;
  right: -3rpx;
  bottom: -3rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.4);
}

.avatar-placeholder {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* 内容区域 */
.content-wrapper {
  flex: 1;
  overflow: hidden;
}

.content {
  height: 100%;
  padding: 35rpx 0;
  padding-left: 30rpx;
  padding-right: 30rpx;
  box-sizing: border-box;
}

/* 欢迎卡片 */
.welcome-card {
  margin: var(--nav-bar-bottom-gap) 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, var(--card-bg) 0%, rgba(255, 77, 0, 0.1) 100%);
  border-radius: 24rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.1);
}

/* 区块标题 */
.section {
  margin-top: 40rpx;
}

.section-header {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 新增任务按钮（内联） */
.add-task-btn-inline {
  padding: 8rpx 20rpx;
  background-color: rgba(255, 77, 0, 0.15);
  border-radius: 20rpx;
  border: 1rpx solid var(--primary-color);
}

/* 任务简报 */
.tasks-brief {
  padding: 0 30rpx;
}

.task-item {
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.task-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid var(--text-muted);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-checkbox.checked {
  background-color: var(--primary-color);
  border-color: var(--primary-color);
}

.checkbox-icon {
  color: var(--text-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.task-info {
  display: flex;
  flex-direction: column;
}

.task-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.task-sets {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.task-status {
  font-size: 24rpx;
}

/* 快速操作 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 0 30rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.action-label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 悬浮按钮 */
.fab-checkin {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(255, 77, 0, 0.5);
  z-index: 999;
}

.fab-checkin:active {
  transform: translateX(-50%) scale(0.95);
  box-shadow: 0 4rpx 20rpx rgba(255, 77, 0, 0.4);
}

.fab-checkin-icon {
  font-size: 60rpx;
  color: var(--text-primary);
  font-weight: 300;
  line-height: 1;
}

/* 快捷记录弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.quick-record-card {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 calc(40rpx + env(safe-area-inset-bottom)) 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
}

.quick-record-card.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  position: relative;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: var(--text-muted);
  line-height: 1;
}

/* 记录类型选择 */
.record-type-grid {
  display: flex;
  gap: 30rpx;
  padding: 40rpx 30rpx;
}

.record-type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background-color: var(--bg-color);
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.record-type-item:active {
  border-color: var(--primary-color);
  background-color: rgba(255, 77, 0, 0.1);
}

.record-type-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 20rpx;
}

.record-type-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.record-type-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 记录表单 */
.record-form {
  padding: 0 30rpx 30rpx;
}

.form-section {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.angle-input-row,
.weight-input-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.angle-input {
  flex: 1;
}

.input-suffix {
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 单位选择器 */
.unit-selector {
  display: flex;
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 4rpx;
}

.unit-option {
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.unit-option.active {
  background-color: var(--primary-color);
  color: var(--text-primary);
}

.form-divider {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
}

.divider-text {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 照片上传区域 */
.photo-upload-area {
  width: 100%;
  height: 300rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  border: 2rpx dashed var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.angle-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 表单操作按钮 */
.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.form-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.form-btn-primary {
  background-color: var(--primary-color);
  color: var(--text-primary);
}

.form-btn-secondary {
  background-color: var(--bg-color);
  color: var(--text-secondary);
}

/* 新增任务弹窗 */
.add-task-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1001;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.add-task-content {
  width: 100%;
  background-color: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}

.add-task-form {
  margin-top: 30rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item.half {
  flex: 1;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  padding: 0 30rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 96rpx;
  box-sizing: border-box;
}

.form-input-placeholder {
  color: var(--text-muted);
  font-size: 26rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.date-range {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker-btn {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.date-separator {
  color: var(--text-muted);
  font-size: 28rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-40 {
  margin-top: 40rpx;
}
