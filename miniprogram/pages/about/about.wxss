/* pages/about/about.wxss */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #1A1A1A;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  height: 88rpx;
  box-sizing: border-box;
}

.nav-left,
.nav-right {
  width: 60rpx;
  display: flex;
  align-items: center;
}

.back-btn {
  font-size: 56rpx;
  font-weight: 300;
  color: #FFFFFF;
  line-height: 1;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 内容区域 */
.content {
  padding: 20rpx 0;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
}

.logo-wrapper {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, var(--card-bg) 0%, rgba(255, 77, 0, 0.15) 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 77, 0, 0.2);
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 6rpx 20rpx;
  background-color: rgba(255, 77, 0, 0.1);
  border-radius: 20rpx;
}

/* 卡片区块 */
.section-card {
  margin: 0 30rpx;
  background-color: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 功能列表 */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
}

.feature-icon {
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(255, 77, 0, 0.1);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: 8rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 适用人群 */
.target-users {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.user-tag {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.user-tag-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.user-tag-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 使用指南 */
.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
}

.guide-num {
  width: 44rpx;
  height: 44rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.guide-content {
  flex: 1;
  padding-top: 6rpx;
}

.guide-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.guide-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 免责声明 */
.disclaimer {
  background-color: rgba(255, 77, 0, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 4rpx solid var(--primary-color);
}

.disclaimer-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 联系我们 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.contact-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 底部版权 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
}

.footer-text {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}
