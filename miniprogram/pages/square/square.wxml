<wxs module="utils">
module.exports = {
  isSelected: function(arr, item) {
    for (var i = 0; i < arr.length; i++) {
      if (arr[i] === item) return true;
    }
    return false;
  }
}
</wxs>

<!--pages/square/square.wxml-->
<view class="page-container">
  <!-- 顶部导航栏 - 动态高度 -->
  <view class="nav-bar" style="height: {{navBarHeight}};">
    <view class="nav-content">
      <view class="nav-left"></view>
      <text class="page-title">伤友广场</text>
      <!-- 筛选按钮 -->
      <view class="filter-btn {{hasActiveFilter ? 'active' : ''}}" bindtap="toggleFilter">
        <text class="filter-text text-caption">{{hasActiveFilter ? '筛选中' : '筛选'}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel {{showFilter ? 'show' : ''}}" bindtap="closeFilter">
    <view class="filter-content" catchtap>
      <view class="filter-header">
        <text class="filter-title text-h3">筛选</text>
        <view class="filter-close" bindtap="closeFilter">×</view>
      </view>

      <view class="filter-scroll">
        <!-- 关键词搜索 -->
        <view class="filter-section">
          <view class="filter-section-title">
            <text class="text-body text-secondary">关键词搜索</text>
          </view>
          <view class="filter-search-wrap">
            <input
              class="filter-search-input"
              placeholder="如：胫骨平台骨折、半月板撕裂"
              placeholder-class="filter-search-placeholder"
              value="{{filterKeyword}}"
              bindinput="onFilterKeywordInput"
            />
            <text class="filter-search-icon">🔍</text>
          </view>
          <view class="filter-keyword-hint" wx:if="{{filterKeyword}}">
            <text class="text-caption text-muted">点击"应用筛选"搜索包含「{{filterKeyword}}」的帖子</text>
          </view>
        </view>

        <!-- 损伤部位 -->
        <view class="filter-section">
          <view class="filter-section-title">
            <text class="text-body text-secondary">损伤部位</text>
          </view>
          <view class="filter-tags-row">
            <view
              class="filter-tag {{selectedPart === item.id ? 'selected' : ''}}"
              wx:for="{{filterTags}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="selectPartFilter"
            >
              {{item.name}}
            </view>
          </view>

          <!-- 详细部位（选中大类后显示） -->
          <view class="filter-tags-row sub-tags" wx:if="{{selectedPart && detailOptions.length > 0}}">
            <view
              class="filter-tag small {{selectedPartDetail === item.id ? 'selected' : ''}}"
              wx:for="{{detailOptions}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="selectPartDetailFilter"
            >
              {{item.name}}
            </view>
          </view>
        </view>

        <!-- 损伤类型（选中详细部位后显示） -->
        <view class="filter-section" wx:if="{{selectedPartDetail && injuryTypeOptions.length > 0}}">
          <view class="filter-section-title">
            <text class="text-body text-secondary">损伤类型</text>
          </view>
          <view class="filter-tags-row">
            <view
              class="filter-tag small {{selectedInjuryType === item.id ? 'selected' : ''}}"
              wx:for="{{injuryTypeOptions}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="selectInjuryTypeFilter"
            >
              {{item.name}}
            </view>
          </view>
        </view>

        <!-- 运动背景 -->
        <view class="filter-section">
          <view class="filter-section-title">
            <text class="text-body text-secondary">运动背景</text>
          </view>
          <view class="filter-tags-row">
            <view
              class="filter-tag {{selectedSportBackground === item.id ? 'selected' : ''}}"
              wx:for="{{sportBackgroundOptions}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="selectSportBgFilter"
            >
              {{item.name}}
            </view>
          </view>

          <!-- 运动爱好者子选项 -->
          <view class="filter-tags-row sub-tags" wx:if="{{selectedSportBackground === 'amateur'}}">
            <view
              wx:for="{{sportsFilterOptions}}"
              wx:key="id"
              class="filter-tag small {{utils.isSelected(selectedSports, item.id) ? 'selected' : ''}}"
              data-id="{{item.id}}"
              catchtap="onSelectSport"
            >
              {{item.name}}
            </view>
          </view>
        </view>
      </view>

      <!-- 筛选操作按钮 -->
      <view class="filter-actions">
        <view class="filter-reset" bindtap="resetFilter">
          <text class="text-body">重置</text>
        </view>
        <view class="filter-confirm" bindtap="applyFilter">
          <text class="text-body text-white">应用筛选</text>
        </view>
      </view>
    </view>
  </view>

  <scroll-view class="content" scroll-y="{{true}}" style="height: 100vh;" bindscroll="onScroll">
    <!-- 筛选结果为空提示 -->
    <view class="empty-filter-result" wx:if="{{displayPosts.length === 0 && hasActiveFilter}}">
      <text class="empty-icon">🔍</text>
      <text class="text-body text-secondary">暂无符合条件的帖子</text>
      <view class="reset-hint" bindtap="resetFilter">
        <text class="text-caption text-orange">点击重置筛选</text>
      </view>
    </view>

    <!-- 动态列表 -->
    <view class="posts-list" wx:else>
      <view class="post-card card" wx:for="{{displayPosts}}" wx:key="id">
        <!-- 用户信息 -->
        <view class="post-header">
          <view class="user-info" data-userid="{{item.authorId}}" data-authorid="{{item.authorId}}" bindtap="viewUserProfile">
            <view class="user-avatar">
              <image wx:if="{{item.authorAvatar}}" src="{{item.authorAvatar}}" mode="aspectFill"></image>
              <text wx:else class="avatar-placeholder-icon">👤</text>
            </view>
            <view class="user-details">
              <text class="user-name text-body">{{item.authorName}}</text>
              <view class="user-tags">
                <text class="user-tag text-caption">{{item.injuryPart}}</text>
                <text class="user-tag text-caption">{{item.injuryType}}</text>
                <text class="user-tag text-caption text-blue">{{item.injuryReason}}</text>
                <text class="user-tag text-caption text-purple">{{item.sportBackground}}</text>
                <text class="user-tag text-caption text-green" wx:for="{{item.sportsItems}}" wx:for-item="sportItem" wx:key="index">{{sportItem}}</text>
                <text class="user-tag text-caption text-orange" wx:if="{{item.daysSinceSurgery > 0}}">术后{{item.daysSinceSurgery}}天</text>
              </view>
            </view>
          </view>
          <view class="post-header-right">
            <text class="post-time text-caption text-muted">{{item.createTime}}</text>
            <text class="post-delete text-muted" wx:if="{{item.authorId === currentUserId}}" data-id="{{item.id}}" catchtap="deletePost">删除</text>
          </view>
        </view>

        <!-- 动态内容 -->
        <view class="post-content">
          <text class="content-text text-body">{{item.content}}</text>
        </view>

        <!-- 动态图片 -->
        <view class="post-images" wx:if="{{item.images && item.images.length > 0}}">
          <image 
            class="post-image" 
            wx:for="{{item.images}}"
            wx:for-item="img"
            wx:key="index"
            src="{{img}}"
            mode="aspectFill"
          ></image>
        </view>

        <!-- 标签 -->
        <view class="post-tags mt-20" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="post-tag text-caption text-orange" wx:for="{{item.tags}}" wx:key="index">{{item}}</text>
        </view>

        <!-- 互动栏 -->
        <view class="post-actions mt-30">
          <view class="action-item {{item.isLiked ? 'liked' : ''}}" data-id="{{item.id}}" bindtap="toggleLike">
            <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
            <text class="action-text text-caption">{{item.likes}}</text>
          </view>
          <view class="action-item" data-id="{{item.id}}" bindtap="commentPost">
            <text class="action-icon">💬</text>
            <text class="action-text text-caption">{{item.comments}}</text>
          </view>
        </view>

        <!-- 评论列表 -->
        <view class="comment-section" wx:if="{{item.showComments && item.commentList.length > 0}}">
          <view class="comment-item" wx:for="{{item.commentList}}" wx:key="id">
            <view class="comment-user">
              <text class="comment-user-name">{{item.userName}}</text>
              <text class="comment-time text-muted">{{item.createTime}}</text>
            </view>
            <text class="comment-content">{{item.content}}</text>
          </view>
        </view>

        <!-- 查看全部评论按钮 -->
        <view class="view-more-comments" wx:if="{{item.showComments && item.comments > 0}}" data-id="{{item.id}}" bindtap="openCommentInput">
          <text class="text-orange text-caption">写评论...</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 发布按钮 -->
  <view class="fab-publish" bindtap="openPublishModal">
    <text class="fab-icon">✏️</text>
  </view>

  <!-- 发布弹窗 -->
  <view class="publish-modal {{showPublishModal ? 'show' : ''}}" bindtap="closePublishModal">
    <view class="publish-content" catchtap="preventBubble">
      <!-- 头部 -->
      <view class="publish-header">
        <text class="publish-cancel text-secondary" bindtap="closePublishModal">取消</text>
        <text class="publish-title text-h3">发布动态</text>
        <text class="publish-submit text-orange" bindtap="publishPost">发布</text>
      </view>

      <!-- 用户信息 -->
      <view class="publish-user-info">
        <view class="user-avatar-small">
          <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"></image>
          <text wx:else class="avatar-placeholder-icon">👤</text>
        </view>
        <view class="user-tags-row">
          <text class="user-tag text-caption">{{userInfo.injuryPart}}</text>
          <text class="user-tag text-caption">{{userInfo.injuryType}}</text>
          <text class="user-tag text-caption text-orange" wx:if="{{userInfo.daysSinceSurgery > 0}}">术后{{userInfo.daysSinceSurgery}}天</text>
        </view>
      </view>

      <!-- 内容输入 -->
      <textarea 
        class="publish-textarea"
        placeholder="分享你的康复历程..."
        value="{{publishContent}}"
        bindinput="inputPublishContent"
        maxlength="500"
      ></textarea>

      <!-- 自动标签提示 -->
      <view class="auto-tags-hint">
        <text class="text-caption text-muted">自动添加标签：</text>
        <text class="text-caption text-orange" wx:if="{{userInfo.daysSinceSurgery > 0}}">#{{userInfo.injuryType}} #术后{{userInfo.daysSinceSurgery}}天</text>
        <text class="text-caption text-orange" wx:else>#{{userInfo.injuryType}}</text>
      </view>

      <!-- 图片列表 -->
      <view class="publish-images" wx:if="{{publishImages.length > 0}}">
        <view class="publish-image-item" wx:for="{{publishImages}}" wx:key="index">
          <image src="{{item}}" mode="aspectFill"></image>
          <view class="image-delete" data-index="{{index}}" bindtap="deletePublishImage">×</view>
        </view>
      </view>

      <!-- 添加图片按钮 -->
      <view class="add-image-btn" bindtap="addPublishImage">
        <text class="add-icon">📷</text>
        <text class="add-text text-caption text-muted">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 评论输入框弹窗 -->
  <view wx:if="{{showCommentInput}}" class="comment-modal show" catchtap="closeCommentInput">
    <view class="comment-input-container" catchtap="preventBubble">
      <input
        class="comment-input"
        placeholder="写下评论..."
        placeholder-class="comment-placeholder"
        value="{{commentInput}}"
        bindinput="inputComment"
        confirm-type="send"
        bindconfirm="sendComment"
        focus="{{showCommentInput}}"
        adjust-position="{{true}}"
      />
      <view class="comment-send-btn {{commentInput ? 'active' : ''}}" bindtap="sendComment">
        <text>发送</text>
      </view>
    </view>
  </view>
</view>
