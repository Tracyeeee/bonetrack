/* pages/square/square.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 120rpx;
}

/* 导航栏 - 沉浸式覆盖 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #1A1A1A;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  height: 88rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
}

/* 内容区域 */
.content {
  padding: 35rpx 0;
}

.content-hidden {
  pointer-events: none;
  opacity: 0.5;
}

/* 筛选栏 */
.filter-bar {
  position: fixed;
  top: calc(var(--status-bar-height, 44px) + 88rpx);
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  background-color: var(--bg-color);
  z-index: 90;
  box-sizing: border-box;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background-color: var(--card-bg);
  border-radius: 30rpx;
  position: relative;
}

.filter-btn.active {
  background-color: var(--primary-color);
}

.filter-icon {
  font-size: 24rpx;
}

.filter-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

.filter-count {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #FF4D00;
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.filter-result {
  flex: 1;
  text-align: right;
  padding-right: 10rpx;
}

/* 筛选面板 */
.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: none;
}

.filter-panel.show {
  display: block;
}

.filter-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.filter-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70vh;
  background-color: var(--card-bg);
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  overflow-y: auto;
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.filter-section-clear {
  font-size: 24rpx;
  color: var(--primary-color);
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 20rpx;
  background-color: var(--bg-color);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.filter-tag.selected {
  background-color: var(--primary-color);
  color: #FFFFFF;
}

.filter-tag .tag-name {
  margin-left: 4rpx;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.filter-reset-btn {
  flex: 1;
  padding: 24rpx;
  background-color: var(--bg-color);
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
}

.filter-confirm-btn {
  flex: 2;
  padding: 24rpx;
  background-color: var(--primary-color);
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 筛选标签 */
.filter-scroll {
  padding: 20rpx 30rpx;
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
  gap: 20rpx;
}

.filter-tab {
  padding: 14rpx 28rpx;
  background-color: var(--card-bg);
  border-radius: 40rpx;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.filter-tab.active {
  background-color: var(--primary-color);
}

.filter-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filter-tab.active .filter-text {
  color: var(--text-primary);
}

/* 动态列表 */
.posts-list {
  padding: 0 30rpx;
}

.post-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

/* 用户信息 */
.post-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder-icon {
  font-size: 40rpx;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.user-tag {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 4rpx 12rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 6rpx;
}

.user-tag.text-orange {
  background-color: rgba(255, 77, 0, 0.15);
}

.user-tag.text-blue {
  background-color: rgba(25, 130, 255, 0.15);
}

.user-tag.text-purple {
  background-color: rgba(155, 89, 182, 0.15);
}

.post-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 动态内容 */
.post-content {
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-primary);
}

/* 动态图片 */
.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.post-image {
  aspect-ratio: 1;
  border-radius: 12rpx;
  object-fit: cover;
}

/* 标签 */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.post-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  background-color: rgba(255, 77, 0, 0.1);
  border-radius: 30rpx;
}

/* 互动栏 */
.post-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0;
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.action-item.liked .action-text {
  color: #FF4757;
}

/* 发布按钮 */
.fab-publish {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(255, 77, 0, 0.5);
  z-index: 999;
}

.fab-publish:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 48rpx;
}

/* 发布弹窗 */
.publish-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  z-index: 1000;
  display: none;
  align-items: flex-end;
  justify-content: center;
}

.publish-modal.show {
  display: flex;
}

.publish-content {
  width: 100%;
  max-height: 90vh;
  background-color: var(--card-bg);
  border-radius: 40rpx 40rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

.publish-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.publish-cancel,
.publish-submit {
  font-size: 30rpx;
  padding: 10rpx 20rpx;
}

.publish-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 发布用户信息 */
.publish-user-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.user-avatar-small image {
  width: 100%;
  height: 100%;
}

.user-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 文本框 */
.publish-textarea {
  width: 100%;
  min-height: 200rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
}

.publish-textarea::placeholder {
  color: var(--text-muted);
}

/* 自动标签提示 */
.auto-tags-hint {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 16rpx;
  background-color: var(--bg-color);
  border-radius: 12rpx;
}

/* 发布图片列表 */
.publish-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.publish-image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
}

.publish-image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.6);
  color: var(--text-primary);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 添加图片按钮 */
.add-image-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  width: 100%;
  height: 200rpx;
  background-color: var(--bg-color);
  border: 2rpx dashed var(--text-muted);
  border-radius: 16rpx;
}

.add-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

/* 评论列表 */
.comment-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.comment-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-user-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.comment-time {
  font-size: 20rpx;
}

.comment-content {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.view-more-comments {
  padding: 16rpx 0;
  margin-top: 10rpx;
}

/* 评论输入框弹窗 */
.comment-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.comment-modal.show {
  opacity: 1;
  visibility: visible;
}

.comment-input-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--card-bg);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.comment-input {
  flex: 1;
  height: 80rpx;
  padding: 0 30rpx;
  background-color: var(--bg-color);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.comment-input::placeholder {
  color: var(--text-muted);
}

.comment-send-btn {
  padding: 16rpx 32rpx;
  background-color: rgba(255, 77, 0, 0.3);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-muted);
  transition: all 0.2s ease;
}

.comment-send-btn.active {
  background-color: var(--primary-color);
  color: var(--text-primary);
}
