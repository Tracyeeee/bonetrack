/* pages/calendar/calendar.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

/* 导航栏 - 沉浸式覆盖 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #1A1A1A;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  height: 88rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
}

/* 内容区域 */
.content {
  padding: 35rpx 0;
}

/* 统计卡片 */
.stats-card {
  margin: 20rpx 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, var(--card-bg) 0%, rgba(255, 77, 0, 0.08) 100%);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.1);
}

/* 日历区块 */
.calendar-section {
  margin: 20rpx 30rpx;
  padding: 30rpx;
}

/* 月份切换 */
.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.month-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 48rpx;
  color: var(--primary-color);
  font-weight: 300;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 星期标题 */
.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 20rpx;
}

.week-day {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 10rpx 0;
}

/* 日期网格 */
.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.2s ease;
  padding-top: 8rpx;
  padding-bottom: 40rpx;
}

.day-cell.empty {
  background-color: transparent;
}

.day-cell:not(.empty) {
  background-color: var(--bg-color);
}

.day-cell.today {
  border: 2rpx solid var(--primary-color);
}

.day-cell.has-record {
  background-color: rgba(255, 77, 0, 0.15);
}

.day-cell.future {
  opacity: 0.4;
}

.day-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.day-cell.today .day-text {
  color: var(--primary-color);
  font-weight: 700;
}

/* 记录标记点 */
.record-dot {
  position: absolute;
  bottom: 6rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
}

.angle-dot {
  width: auto;
  height: auto;
  padding: 1rpx 4rpx;
  border-radius: 4rpx;
  background-color: rgba(255, 77, 0, 0.9);
  max-width: 80%;
}

.angle-value {
  font-size: 18rpx;
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.2;
}

/* 记录标记容器 */
.record-marks {
  position: absolute;
  bottom: 4rpx;
  left: 4rpx;
  right: 4rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4rpx;
  justify-content: center;
}

/* 迷你角度标签 */
.mini-angle-tag {
  font-size: 14rpx;
  color: var(--text-primary);
  font-weight: 600;
  background-color: rgba(255, 77, 0, 0.85);
  padding: 1rpx 4rpx;
  border-radius: 4rpx;
  line-height: 1.3;
  max-width: 90%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-task-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #4CD964;
}

/* 迷你事项标签 */
.mini-event-tag {
  font-size: 12rpx;
  color: #FFFFFF;
  font-weight: 600;
  background-color: #5856D6;
  padding: 1rpx 4rpx;
  border-radius: 4rpx;
  line-height: 1.3;
  max-width: 90%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 完成训练标签 */
.mini-completed-tag {
  font-size: 12rpx;
  color: #FFFFFF;
  font-weight: 600;
  background-color: #007AFF;
  padding: 1rpx 4rpx;
  border-radius: 4rpx;
  line-height: 1.3;
  max-width: 90%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 照片标记点 */
.photo-dot {
  position: absolute;
  bottom: 6rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #4CD964;
}

/* 图例 */
.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
}

.legend-dot.completed-dot {
  background-color: #007AFF;
}

.legend-dot.angle-dot {
  width: auto;
  height: auto;
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
}

.legend-dot.photo-dot {
  background-color: #4CD964;
}

/* 事项标签图例 */
.legend-dot.event-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #5856D6;
  border-radius: 4rpx;
}

/* 记录详情弹窗 */
.record-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  z-index: 1000;
  display: none;
  align-items: flex-end;
  justify-content: center;
}

.record-modal.show {
  display: flex;
}

.record-modal-content {
  width: 100%;
  max-height: 70vh;
  background-color: var(--card-bg);
  border-radius: 40rpx 40rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-muted);
}

/* 日期类型标识 */
.date-type-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  background-color: rgba(255, 77, 0, 0.15);
}

.date-type-text {
  font-size: 24rpx;
  color: var(--primary-color);
}

/* 事项显示 */
.event-section {
  margin-top: 24rpx;
  padding: 20rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
}

.event-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.event-icon {
  font-size: 32rpx;
}

.event-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.quick-add-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* 事项快捷标签 */
.event-quick-tags {
  margin-top: 24rpx;
}

.event-quick-label {
  display: block;
  margin-bottom: 12rpx;
}

.quick-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-tag {
  padding: 12rpx 20rpx;
  background-color: var(--bg-color);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.quick-tag.selected {
  background-color: rgba(88, 86, 214, 0.2);
  color: #5856D6;
  border-color: #5856D6;
}

/* 补充打卡区块 */
.supplement-checkin {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 操作按钮 */
.event-btn {
  background-color: rgba(88, 86, 214, 0.2);
  color: #5856D6;
}

/* 照片预览 */
.photo-preview-section {
  margin-bottom: 30rpx;
}

.section-label {
  display: block;
  margin-bottom: 16rpx;
}

/* 任务列表样式 */
.tasks-list-section {
  margin-bottom: 24rpx;
}

.tasks-list {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 16rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.task-item:last-child {
  border-bottom: none;
}

.task-item.completed {
  opacity: 0.7;
}

.task-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.task-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.task-status {
  font-size: 24rpx;
  font-weight: 600;
}

.task-status.done {
  color: #007AFF;
}

.task-status.pending {
  color: var(--text-muted);
}

.photo-scroll {
  white-space: nowrap;
}

.photo-list {
  display: inline-flex;
  gap: 16rpx;
}

.preview-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

/* 数据项 */
.data-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.data-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 77, 0, 0.15);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.data-info {
  display: flex;
  flex-direction: column;
}

.data-label {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.data-value {
  font-size: 40rpx;
  font-weight: 700;
}

/* 无记录 */
.no-record {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

/* 趋势图表 */
.angle-trend {
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.trend-chart {
  height: 120rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-top: 20rpx;
}

.trend-bar {
  width: 60rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.trend-fill {
  width: 100%;
  background-color: var(--primary-color);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 10rpx;
}

.trend-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-top: 8rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input::placeholder {
  color: var(--text-muted);
}

/* 图标选择器 */
.icon-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.icon-option {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-color);
  border-radius: 12rpx;
  font-size: 36rpx;
  transition: all 0.2s ease;
}

.icon-option.selected {
  background-color: rgba(255, 77, 0, 0.2);
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 0, 0.3);
}

/* 主要按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary-outline {
  width: 100%;
  height: 88rpx;
  background-color: transparent;
  color: var(--primary-color);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--primary-color);
}

/* 记录操作按钮 */
.record-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.record-actions .action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.record-actions .edit-btn {
  background-color: rgba(255, 77, 0, 0.15);
  color: var(--primary-color);
}

.record-actions .delete-btn {
  background-color: rgba(255, 59, 48, 0.15);
  color: #FF3B30;
}

/* 编辑操作按钮 */
.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background-color: var(--bg-color);
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel:active {
  opacity: 0.8;
}

.btn-primary-sm {
  flex: 2;
  height: 88rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary-sm:active {
  opacity: 0.8;
}

/* 底部间距 */
.mb-20 {
  margin-bottom: 20rpx;
}

/* 康复指南区块 */
.guide-section {
  padding: 0 30rpx;
  padding-bottom: 40rpx;
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
}

.category-tabs {
  display: inline-flex;
  gap: 20rpx;
  padding: 10rpx 0;
}

.category-tab {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background-color: var(--card-bg);
  border-radius: 40rpx;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.category-tab.active {
  background-color: var(--primary-color);
}

.category-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.category-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.category-tab.active .category-name {
  color: #FFFFFF;
}

/* 动作列表 */
.exercise-list {
  margin-top: 20rpx;
}

.exercise-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.exercise-header {
  display: flex;
  align-items: center;
}

.exercise-icon-box {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 77, 0, 0.15);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.exercise-icon-text {
  font-size: 40rpx;
}

.exercise-basic {
  flex: 1;
}

.exercise-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.exercise-meta {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.exercise-desc {
  display: block;
  line-height: 1.6;
}

.exercise-footer {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.tip-icon {
  margin-right: 10rpx;
}

.exercise-tip {
  flex: 1;
}

/* 动作详情弹窗 */
.exercise-detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  z-index: 1001;
  display: none;
  align-items: flex-end;
  justify-content: center;
}

.exercise-detail-modal.show {
  display: flex;
}

.exercise-detail-content {
  width: 100%;
  max-height: 85vh;
  background-color: var(--card-bg);
  border-radius: 40rpx 40rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

.detail-header {
  display: flex;
  align-items: flex-start;
  position: relative;
  padding-right: 60rpx;
}

.detail-icon-box {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255, 77, 0, 0.15);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.detail-icon-text {
  font-size: 50rpx;
}

.detail-title-section {
  flex: 1;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.detail-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.detail-section {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-desc {
  line-height: 1.8;
}

/* 要点列表 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-number {
  width: 40rpx;
  height: 40rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  line-height: 1.6;
  color: var(--text-secondary);
}

/* 详情操作按钮 */
.detail-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.detail-actions .action-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.detail-actions .btn-secondary {
  background-color: var(--bg-color);
  color: var(--text-secondary);
}

.detail-actions .btn-primary {
  background-color: var(--primary-color);
  color: #FFFFFF;
}
